---
import { Icon } from 'astro-icon/components';

interface Props {
  name: string;
  label: string;
  type?: 'text' | 'email' | 'password' | 'tel' | 'url' | 'number';
  placeholder: string;
  defaultValue?: string;
  error?: string;
}

const {
  name,
  label,
  placeholder,
  error,
  type = 'text',
  defaultValue = '',
} = Astro.props;
---

<div class="flex flex-col gap-2">
  <label
    for={name}
    class="block text-sm font-medium leading-6 text-gray-100"
  >
    {label}
  </label>
  <div class="relative">
    <input
      type={type}
      name={name}
      id={name}
      class="block w-full rounded-md border-0 px-2 py-1.5 text-gray-900 shadow-sm outline-none ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-accent sm:text-sm sm:leading-6"
      placeholder={placeholder}
      value={defaultValue}
      aria-invalid={error ? 'true' : 'false'}
      aria-describedby={`${name}-error`}
    />
    {
      error && (
        <div class="pointer-events-none absolute right-0 top-1.5 flex items-center pr-3">
          <Icon
            name="lucide:alert-circle"
            class="size-5 text-red-500"
            aria-hidden="true"
          />
        </div>
      )
    }
  </div>
  {error && <p class="text-sm text-red-500" id={`${name}-error`}>{error}</p>}
</div>
