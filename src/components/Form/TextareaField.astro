---
import { AlertCircle } from 'lucide-react';

interface Props {
  name: string;
  label: string;
  rows?: number;
  defaultValue?: string;
  placeholder: string;
  error?: string;
}

const {
  name,
  label,
  placeholder,
  error,
  rows = 4,
  defaultValue = '',
} = Astro.props;
---

<div class="flex flex-col gap-2">
  <label
    for={name}
    class="block text-sm font-medium leading-6 text-gray-100"
  >
    {label}
  </label>
  <div class="relative rounded-md shadow-sm">
    <textarea
      rows={rows}
      name={name}
      id={name}
      class="block w-full rounded-md border-0 px-2 py-1.5 text-gray-900 shadow-sm outline-none ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-accent sm:text-sm sm:leading-6"
      placeholder={placeholder}
      aria-invalid={error ? 'true' : 'false'}
      aria-describedby={`${name}-error`}>{defaultValue}</textarea
    >
    {
      error && (
        <div class="pointer-events-none absolute right-0 top-1.5 flex items-center pr-3">
          <AlertCircle className="size-5 text-red-500" aria-hidden="true" />
        </div>
      )
    }
  </div>
  {error && <p class="text-sm text-red-500" id={`${name}-error`}>{error}</p>}
</div>
