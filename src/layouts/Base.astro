---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  current?: 'writing' | 'projects' | 'about';
}

const { title, description, current } = Astro.props;

const navLink = 'text-sm text-text-2 transition-colors duration-120 hover:text-text max-md:text-[13px]';
const navLinks = [
  { href: '/writing/', label: 'Writing', key: 'writing' },
  { href: '/projects/', label: 'Projects', key: 'projects' },
  { href: '/about/', label: 'About', key: 'about' },
] as const;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
{description && <meta name="description" content={description} />}
<link rel="alternate" type="application/rss+xml" title="dbtlr.com — Writing" href="/feed.xml" />
</head>
<body>
<div class="col">
  <header class="flex items-baseline justify-between pt-10 max-md:pt-6">
    <a class="font-bold text-[17px] tracking-[-0.01em]" href="/">dbtlr<i class="not-italic text-accent-warm">.</i>com</a>
    <nav class="flex gap-7 max-md:gap-4.5">
      {navLinks.map((l) => (
        <a href={l.href} class:list={[navLink, { 'text-text': current === l.key }]}>{l.label}</a>
      ))}
      <button
        class="searchbtn inline-flex items-center gap-1.75 self-center font-mono text-[10.5px] tracking-[0.04em] text-text-3 bg-transparent border border-line-strong rounded-md px-2.25 py-1 cursor-pointer transition-colors duration-120 hover:text-text hover:border-text-3"
        type="button"
        aria-label="Search"
      ><svg class="block" width="11" height="11" viewBox="0 0 12 12" fill="none"><circle cx="5" cy="5" r="3.6" stroke="currentColor" stroke-width="1.3"></circle><path d="M8 8 L11 11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></path></svg><span class="max-md:hidden">⌘K</span></button>
    </nav>
  </header>
</div>

<slot />

<div class="h-16"></div>

<footer class="mt-auto">
  <div class="col">
    <div class="border-t border-line pt-6 pb-9 flex justify-between gap-4 text-[13px] text-text-3 max-md:flex-col max-md:gap-2.5">
      <span>© 2026 dbtlr</span>
      <span class="flex gap-5">
        <a class="text-text-2 transition-colors duration-120 hover:text-text" href="#">GitHub</a>
        <a class="text-text-2 transition-colors duration-120 hover:text-text" href="/feed.xml">RSS</a>
        <a class="text-text-2 transition-colors duration-120 hover:text-text" href="#">Email</a>
      </span>
    </div>
  </div>
</footer>

<script>
  import '../scripts/copy.js';
  import '../scripts/search.js';
</script>
</body>
</html>
