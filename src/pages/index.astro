---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import SectionHead from '../components/SectionHead.astro';
import PostRow from '../components/PostRow.astro';
import { fmtLong } from '../lib/format';

const posts = (await getCollection('writing'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---
<Base title="dbtlr.com" description="Software, written down. Writing and projects on distributed systems, developer tools, and keeping software simple.">
  <div class="col">
    <section class="pt-22 pb-16 max-md:pt-13 max-md:pb-10">
      <h1 class="m-0 mb-5 text-[40px] leading-[1.18] font-semibold tracking-[-0.015em] max-md:text-3xl">Software, written down.</h1>
      <p class="m-0 text-[17px] leading-[1.65] text-text-2 max-w-[56ch] max-md:text-[15.5px]">
        I’m a software engineer who builds developer tools and writes about distributed systems, data
        plumbing, and the craft of keeping software simple. Currently building
        <a class="text-accent-cool border-b border-transparent hover:border-cool-dim" href="/projects/relaymesh/">relaymesh</a>.
      </p>
    </section>

    <SectionHead label="Recent writing" href="/writing/" linkText="All posts →" />
    {posts.map((post) => (
      <PostRow
        href={`/writing/${post.id}/`}
        date={fmtLong(post.data.date)}
        title={post.data.title}
        blurb={post.data.blurb}
      />
    ))}

    <SectionHead label="Selected projects" href="/projects/" linkText="All projects →" class="mt-14" />
    {projects.map((project) => (
      <a class="group flex items-baseline gap-3.5 py-4 border-b border-line max-md:flex-wrap max-md:gap-y-1" href={`/projects/${project.id}/`}>
        <b class="text-base font-semibold transition-colors duration-120 group-hover:text-accent-cool">{project.data.name}</b>
        <span class="text-sm text-text-2">{project.data.blurb}</span>
        <em class="ml-auto not-italic font-mono text-[11.5px] text-accent-warm shrink-0 max-md:ml-0 max-md:w-full">{project.data.lang}</em>
      </a>
    ))}
  </div>
</Base>
