---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---
<Base title="Projects — dbtlr.com" description="Tools I build and maintain — mostly small, sharp, and self-hosted." current="projects">
  <div class="col">
    <section class="pt-18 pb-10 max-md:pt-12">
      <h1 class="m-0 mb-3.5 text-[34px] font-semibold tracking-[-0.015em] max-md:text-[28px]">Projects</h1>
      <p class="m-0 text-base leading-[1.6] text-text-2 max-w-[58ch]">Tools I build and maintain — mostly small, sharp, and self-hosted. Screenshots are placeholders until the real things land here.</p>
    </section>

    {projects.map((project) => (
      <a class="group grid grid-cols-[180px_1fr] gap-7 items-start py-7 border-b border-line max-md:grid-cols-1 max-md:gap-3.5" href={`/projects/${project.id}/`}>
        <div class="ph min-h-0 h-27.5 max-md:h-35"><span>{project.data.thumbLabel}</span></div>
        <span>
          <h3 class="m-0 mb-1.5 text-[19px] font-semibold tracking-[-0.01em] transition-colors duration-120 group-hover:text-accent-cool">{project.data.name}</h3>
          <p class="m-0 mb-2.5 text-[14.5px] leading-[1.55] text-text-2 max-w-[52ch]">{project.data.description}</p>
          <span class="flex gap-3.5 font-mono text-[11.5px]">
            <span class="text-accent-warm">{project.data.lang}</span>
            <span class="text-text-3">{project.data.status} · {project.data.version}</span>
          </span>
        </span>
      </a>
    ))}
  </div>
</Base>
